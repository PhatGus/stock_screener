# Financial Modeling Prep (FMP) API key — primary data source for the screener.
# Copy this file to `.env` and fill in your key, OR export it in your shell:
#     export FMP_API_KEY=your_key_here
#
# The application reads the key from the FMP_API_KEY environment variable.
# `.env` itself is gitignored so your key is never committed.
FMP_API_KEY=your_key_here
